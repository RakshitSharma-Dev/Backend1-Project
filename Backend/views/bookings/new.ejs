<% layout('/layouts/boilerplate') %>

<div class="form-page">
    <div class="form-wrapper">
        <h2 class="form-title">Reserve: <%= listing.title %></h2>
        <p class="form-subtitle">₹ <%= listing.price.toLocaleString('en-IN') %> / night — <%= listing.location %>, <%= listing.country %></p>

        <div class="booking-section" data-night-price="<%= listing.price %>">
            <form action="/booking/<%= listing._id %>/bookings" method="POST" class="booking-form needs-validation" novalidate>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="checkIn" class="form-label">Check-in</label>
                        <input type="date" id="checkIn" name="booking[checkIn]" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label for="checkOut" class="form-label">Check-out</label>
                        <input type="date" id="checkOut" name="booking[checkOut]" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label for="guests" class="form-label">Guests</label>
                        <input type="number" id="guests" name="booking[guests]" class="form-control" min="1" max="20" value="1" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Estimated total</label>
                        <div class="booking-total-box">₹ <span id="bookingTotal">0</span></div>
                        <input type="hidden" id="totalPrice" name="booking[totalPrice]" value="0">
                    </div>
                    <div class="col-12">
                        <label for="specialRequests" class="form-label">Special requests</label>
                        <textarea id="specialRequests" name="booking[specialRequests]" class="form-control booking-textarea" placeholder="Anything we should know before your stay?"></textarea>
                    </div>
                </div>

                <div style="display:flex;gap:0.75rem;margin-top:1rem;">
                    <button type="button" class="form-submit-btn booking-submit-btn" data-bs-toggle="modal" data-bs-target="#paymentModal">Book Now</button>
                    <a href="/listing/<%= listing._id %>" class="btn-delete" style="align-self:center;">Back</a>
                </div>
            </form>
        </div>

    </div>
</div>

<!-- Dummy Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="paymentModalLabel">Secure Payment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="dummyPaymentForm">
          <div class="mb-3">
            <label for="cardNumber" class="form-label">Card Number</label>
            <input type="text" class="form-control" id="cardNumber" placeholder="0000 0000 0000 0000" required pattern="\d{16}" title="16 digit card number">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="expiry" class="form-label">Expiry Date</label>
              <input type="text" class="form-control" id="expiry" placeholder="MM/YY" required pattern="\d{2}/\d{2}" title="MM/YY format">
            </div>
            <div class="col-md-6 mb-3">
              <label for="cvv" class="form-label">CVV</label>
              <input type="password" class="form-control" id="cvv" placeholder="123" required pattern="\d{3,4}" title="3 or 4 digit CVV">
            </div>
          </div>
          <div class="mb-3">
            <label for="nameOnCard" class="form-label">Name on Card</label>
            <input type="text" class="form-control" id="nameOnCard" placeholder="John Doe" required>
          </div>
          <button type="submit" class="btn btn-primary w-100 mt-3" style="background-color: #fe424d; border: none; padding: 0.75rem; border-radius: 8px;">Pay Now & Book</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const paymentForm = document.getElementById("dummyPaymentForm");
        const bookingForm = document.querySelector(".booking-form");

        paymentForm.addEventListener("submit", (e) => {
            e.preventDefault(); // Prevent modal form submission
            
            // Validate main booking form first
            if (!bookingForm.checkValidity()) {
                bookingForm.reportValidity();
                // Close modal so user can see what's missing in the main form
                const modal = bootstrap.Modal.getInstance(document.getElementById('paymentModal'));
                if (modal) modal.hide();
                return;
            }

            // If everything is valid, submit the main booking form
            // This will go to the backend, which will then call the localhost:7000 API
            bookingForm.submit();
        });
    });
</script>
