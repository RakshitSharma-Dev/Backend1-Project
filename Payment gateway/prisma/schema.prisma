generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            String   @id @default(cuid())
  amount        Float
  currency      String
  paymentMethod String
  customerName  String
  reference     String?
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}